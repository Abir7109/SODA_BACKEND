# SODA v2 Environment Variables
# Copy this file to .env (without .example) and fill in your values

# Required: Google AI API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Brave Search API key (for web_search_live tool)
# Get free at: https://brave.com/search/api (2000 searches/month, no credit card)
# If left blank, DuckDuckGo Instant Answer API is used as fallback.
BRAVE_SEARCH_API_KEY=

# Optional: Development settings
# NODE_ENV=development
# PORT=8000

# Required for local frontend dev: points to your Render backend
# VITE_BACKEND_URL=https://soda-backend-sar2.onrender.com

# Email (IMAP/SMTP — Gmail)
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification enabled on your Google account)
# The password is a 16-character code like "abcd efgh ijkl mnop"
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
